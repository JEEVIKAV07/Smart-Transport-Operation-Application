// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  FLEET_MANAGER
  DRIVER
  SAFETY_OFFICER
  FINANCIAL_ANALYST
}

enum VehicleStatus {
  AVAILABLE
  ON_TRIP
  IN_SHOP
  RETIRED
}

enum VehicleType {
  VAN
  TRUCK
  MINI
  BIKE
  BUS
  PICKUP
  CONTAINER
}

enum DriverStatus {
  AVAILABLE
  ON_TRIP
  OFF_DUTY
  SUSPENDED
}

enum LicenseCategory {
  LMV
  HMV
  HPMV
  MGV
  PSV
  MC
}

enum TripStatus {
  DRAFT
  DISPATCHED
  COMPLETED
  CANCELLED
}

enum MaintenanceStatus {
  ACTIVE
  COMPLETED
}

enum ExpenseCategory {
  TOLL
  MAINTENANCE
  FINE
  PERMIT
  INSURANCE
  OTHER
}

enum NotificationType {
  LICENSE_EXPIRY
  MAINTENANCE_DUE
  TRIP_ASSIGNED
  SYSTEM
}

// ─────────────────────────────────────────────
// Models
// ─────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(DRIVER)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notifications Notification[]
  auditLogs     AuditLog[]

  @@map("users")
}

model Vehicle {
  id                 String        @id @default(cuid())
  registrationNumber String        @unique
  name               String
  model              String
  type               VehicleType
  maxLoad            Float         // in kg
  odometer           Float         @default(0) // in km
  acquisitionCost    Float
  purchaseDate       DateTime
  status             VehicleStatus @default(AVAILABLE)
  region             String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt

  trips        Trip[]
  maintenance  Maintenance[]
  fuelLogs     FuelLog[]
  expenses     Expense[]
  documents    VehicleDocument[]

  @@map("vehicles")
}

model Driver {
  id               String       @id @default(cuid())
  name             String
  licenseNumber    String       @unique
  licenseCategory  LicenseCategory
  licenseExpiry    DateTime
  phone            String
  email            String?      @unique
  address          String?
  safetyScore      Float        @default(100)
  status           DriverStatus @default(AVAILABLE)
  emergencyContact String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  trips Trip[]

  @@map("drivers")
}

model Trip {
  id          String     @id @default(cuid())
  tripNumber  String     @unique
  source      String
  destination String
  vehicleId   String
  driverId    String?
  cargoWeight Float      // in kg
  distance    Float      // planned km
  status      TripStatus @default(DRAFT)
  startTime   DateTime?
  endTime     DateTime?
  fuelUsed    Float?     // liters
  revenue     Float?
  notes       String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  vehicle  Vehicle   @relation(fields: [vehicleId], references: [id])
  driver   Driver?   @relation(fields: [driverId], references: [id])
  fuelLogs FuelLog[]
  expenses Expense[]

  @@map("trips")
}

model Maintenance {
  id          String            @id @default(cuid())
  vehicleId   String
  description String
  serviceType String
  status      MaintenanceStatus @default(ACTIVE)
  startDate   DateTime
  endDate     DateTime?
  cost        Float             @default(0)
  notes       String?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("maintenance")
}

model FuelLog {
  id          String   @id @default(cuid())
  vehicleId   String
  tripId      String?
  liters      Float
  cost        Float
  fuelStation String?
  date        DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@map("fuel_logs")
}

model Expense {
  id          String          @id @default(cuid())
  vehicleId   String
  tripId      String?
  category    ExpenseCategory
  description String
  amount      Float
  date        DateTime
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])
  trip    Trip?   @relation(fields: [tripId], references: [id])

  @@map("expenses")
}

model VehicleDocument {
  id         String    @id @default(cuid())
  vehicleId  String
  type       String    // e.g. Insurance, RC, PUC, Permit
  fileName   String
  fileUrl    String
  expiryDate DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  vehicle Vehicle @relation(fields: [vehicleId], references: [id])

  @@map("vehicle_documents")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  isRead    Boolean          @default(false)
  type      NotificationType @default(SYSTEM)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String   // CREATE, UPDATE, DELETE, DISPATCH, COMPLETE, CANCEL
  entity    String   // Vehicle, Driver, Trip, etc.
  entityId  String
  changes   Json?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@map("audit_logs")
}
